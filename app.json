{
  "expo": {
    "name": "Bravely Path — Sobriety & Recovery",
    "slug": "bravely-path",
    "version": "1.0.0",
    "description": "AI-powered addiction recovery coach. Track sobriety, beat cravings, get 24/7 support. Crisis helplines in 10 languages.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "clearpath",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "keywords": "sobriety,addiction recovery,quit drinking,recovery coach,sober tracker,sobriety counter,alcohol free"
    },
    "android": {
      "package": "com.bravelypath.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0C2A4A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c7d6bada-0900-4717-87fa-101124490758"
      }
    }
  }
}
