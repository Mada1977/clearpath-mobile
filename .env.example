# RevenueCat public API key
# Get this from app.revenuecat.com → Project → API Keys
# Safe to embed in the app bundle (EXPO_PUBLIC_ prefix = client-side)
EXPO_PUBLIC_REVENUECAT_API_KEY=your_revenuecat_public_key

# If you prefer per-platform keys instead of a single shared one:
# EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxx
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxx
